#include <iostream>
#include <string>
using namespace std;
class Student
{
private:
    string name;
    int marks;
public:
    void input()
    {
        cout << "Enter Name: ";
        cin >> name;
        cout << "Enter Marks: ";
        cin >> marks;
    }
    int getMarks()
    {
        return marks;
    }

    string getName()
    {
        return name;
    }
};
int main()
{
    int depts;
    cout << "Enter Number of Departments: ";
    cin >> depts;
    int overallTop = -1;
    string overallTopper;
    for(int i=0;i<depts;i++)
    {
        int n;
        cout << "\nEnter Students in Department " << i+1 << ": ";
        cin >> n;
        if(n==0)
        {
            cout << "Department Empty\n";
            continue;
        }
        Student s[100];
        int deptTop=-1, pass=0;
        string deptTopper;
        for(int j=0;j<n;j++)
        {
            s[j].input();
            if(s[j].getMarks() >= 50)
                pass++;
            if(s[j].getMarks() > deptTop)
            {
                deptTop = s[j].getMarks();
                deptTopper = s[j].getName();
            }
        }
        cout << "\nDepartment Topper: "
             << deptTopper << " (" << deptTop << ")\n";
        cout << "Pass Percentage: "
             << (pass*100.0)/n << "%\n";
        if(deptTop > overallTop)
        {
            overallTop = deptTop;
            overallTopper = deptTopper;
        }
    }
    cout << "\nUniversity Topper: "
         << overallTopper << " (" << overallTop << ")\n";
    return 0;
}

